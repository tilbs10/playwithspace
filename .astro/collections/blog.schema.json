{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "category": {
      "type": "string",
      "enum": [
        "fundamentals",
        "coaching",
        "mindset",
        "stories"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "type": {
      "default": "article",
      "type": "string",
      "enum": [
        "article",
        "post-game",
        "post-training"
      ]
    },
    "result": {
      "type": "string"
    },
    "focus": {
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "category"
  ]
}