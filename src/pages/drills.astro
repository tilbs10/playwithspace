---
import BaseLayout from '../layouts/BaseLayout.astro';

const drills = [
  {
    name: "Spatial Awareness Ghost Drill",
    category: "Court vision",
    level: "Intermediate",
    duration: "20 min",
    description: "Players move without the ball and call out which space is open before the pass comes. Simple to run, harder than it sounds.",
    tag: null,
    tagColor: "",
  },
  {
    name: "Catch and decide",
    category: "Decision making",
    level: "All levels",
    duration: "15 min",
    description: "The read happens before the catch, not after. This drill forces players to scan and commit to a decision on the way to the ball.",
    tag: null,
    tagColor: "",
  },
  {
    name: "The wide pin-down",
    category: "Spacing",
    level: "Intermediate",
    duration: "25 min",
    description: "A screen action that creates two reads depending on how the defence responds. Good for teaching players to react rather than execute.",
    tag: null,
    tagColor: "",
  },
  {
    name: "Zone walkthrough",
    category: "Game IQ",
    level: "Beginner",
    duration: "30 min",
    description: "Walk the court at half speed and name the five best spots for each player. Slow work. Shows up in games.",
    tag: null,
    tagColor: "",
  },
  {
    name: "Stop and go",
    category: "Movement",
    level: "Intermediate",
    duration: "20 min",
    description: "Changing pace at the right moment creates space that athleticism alone can't manufacture. This drill isolates that single habit.",
    tag: null,
    tagColor: "",
  },
  {
    name: "Second side reads",
    category: "Decision making",
    level: "Advanced",
    duration: "15 min",
    description: "When the first option closes, most players reset. This drill trains the skip read — what to do when the ball swings quickly to the weak side.",
    tag: "New",
    tagColor: "bg-stone-100 text-stone-600",
  },
];

const levels = ["All", "Beginner", "Intermediate", "Advanced", "All levels"];
const categories = ["All", "Court vision", "Decision making", "Spacing", "Game IQ", "Movement"];
---

<BaseLayout
  title="Drills"
  description="Drills for spacing, court vision, and decision making in youth basketball."
>

  <!-- Page header -->
  <section class="bg-[#006437] py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-4">On the court</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4 leading-tight">Drills</h1>
      <p class="text-white/60 text-base max-w-xl leading-relaxed">
        These are the drills that actually made a difference in sessions. Nothing exotic — just things that worked.
      </p>
    </div>
  </section>

  <!-- Drills grid -->
  <section class="py-16 sm:py-20 bg-[#fafaf9]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">

      <!-- Filter row -->
      <div class="flex flex-wrap gap-2 mb-10">
        {["All", "Beginner", "Intermediate", "Advanced"].map(level => (
          <span class={`text-xs font-semibold px-4 py-2 rounded-full border cursor-pointer transition-colors ${
            level === 'All'
              ? 'bg-stone-900 text-white border-stone-900'
              : 'bg-white text-stone-500 border-stone-200 hover:border-stone-400'
          }`}>
            {level}
          </span>
        ))}
        <div class="w-px bg-stone-200 mx-1 self-stretch"></div>
        {["Court vision", "Decision making", "Spacing", "Game IQ", "Movement"].map(cat => (
          <span class="text-xs font-semibold px-4 py-2 rounded-full border bg-white text-stone-500 border-stone-200 hover:border-stone-400 cursor-pointer transition-colors">
            {cat}
          </span>
        ))}
      </div>

      <!-- Cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {drills.map(drill => (
          <div class="bg-white rounded-[32px] border border-stone-200 p-7 hover:border-[#006437] hover:shadow-lg transition-all group flex flex-col">

            <div class="flex items-center justify-between mb-5">
              <span class="text-[10px] font-bold text-[#006437] uppercase tracking-widest">
                {drill.category}
              </span>
              {drill.tag && (
                <span class={`text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full ${drill.tagColor}`}>
                  {drill.tag}
                </span>
              )}
            </div>

            <h3 class="font-extrabold text-stone-900 text-lg mb-3 leading-snug group-hover:text-[#006437] transition-colors">
              {drill.name}
            </h3>
            <p class="text-sm text-stone-500 leading-relaxed flex-1">
              {drill.description}
            </p>

            <div class="flex items-center justify-between mt-6 pt-5 border-t border-stone-100">
              <div class="flex items-center gap-3">
                <span class="text-xs text-stone-400">{drill.level}</span>
                <span class="text-stone-200">·</span>
                <span class="text-xs text-stone-400">{drill.duration}</span>
              </div>
              <a href="#" class="text-xs font-bold text-[#006437] hover:underline">
                Read →
              </a>
            </div>

          </div>
        ))}
      </div>

      <div class="mt-8 rounded-[32px] border-2 border-dashed border-stone-300 p-12 text-center">
        <p class="text-xs font-semibold text-stone-400 uppercase tracking-widest">
          More added as the season goes on
        </p>
      </div>

    </div>
  </section>

</BaseLayout>
