---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

// Related posts: ranked by shared tags (weighted), then same category,
// then recency. Tag overlap gives far better matches than category alone,
// since most posts share a category.
const currentTags = post.data.tags ?? [];
const related = allPosts
  .filter(p => p.id !== post.id)
  .map(p => {
    const sharedTags = (p.data.tags ?? []).filter(t => currentTags.includes(t)).length;
    const sameCategory = p.data.category === post.data.category ? 1 : 0;
    return { post: p, score: sharedTags * 2 + sameCategory };
  })
  .filter(({ score }) => score > 0)
  .sort((a, b) =>
    b.score - a.score || b.post.data.date.valueOf() - a.post.data.date.valueOf()
  )
  .slice(0, 3)
  .map(({ post: p }) => p);
---

<BlogPost
  title={post.data.title}
  date={post.data.date}
  category={post.data.category}
  type={post.data.type}
  result={post.data.result}
  focus={post.data.focus}
  tags={post.data.tags}
  heroImage={post.data.heroImage}
  heroAlt={post.data.heroAlt}
>
  <Content />

  <!-- Related posts -->
  {related.length > 0 && (
    <div class="mt-12 pt-8 border-t border-stone-200 not-prose">
      <p class="text-xs font-semibold text-stone-400 uppercase tracking-widest mb-5">
        More in {post.data.category}
      </p>
      <div class="grid gap-3">
        {related.map(p => (
          <PostCard
            title={p.data.title}
            date={p.data.date}
            category={p.data.category}
            type={p.data.type}
            slug={p.id}
            result={p.data.result}
            focus={p.data.focus}
          />
        ))}
      </div>
    </div>
  )}
</BlogPost>
