---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Play With Space"
  description="Basketball coaching — space, movement, and the game within the game."
>

  <!-- Hero -->
  <section class="border-b border-stone-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <p class="text-xs font-semibold text-green-800 uppercase tracking-widest mb-5">
        Basketball Coaching Journal
      </p>
      <h1 class="text-4xl sm:text-5xl font-bold text-stone-900 leading-tight mb-6">
        The game is about space.<br />
        Most players never learn to use it.
      </h1>
      <p class="text-lg text-stone-500 max-w-xl leading-relaxed mb-8">
        A coaching journal exploring spacing, movement, and awareness in youth basketball.
        Every session, every game, every lightbulb moment — written down so the lessons don't disappear.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href="/blog"
          class="inline-block bg-green-800 hover:bg-green-900 text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
        >
          Read the blog
        </a>
        <a
          href="/about"
          class="inline-block bg-white hover:bg-stone-50 text-stone-700 font-semibold px-6 py-3 rounded-lg border border-stone-200 transition-colors text-sm"
        >
          What is this?
        </a>
      </div>
    </div>
  </section>

  <!-- Latest posts -->
  <section class="border-b border-stone-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xs font-semibold text-stone-400 uppercase tracking-widest">
          Latest posts
        </h2>
        <a href="/blog" class="text-sm text-green-800 hover:text-green-900 font-medium transition-colors">
          View all →
        </a>
      </div>

      {latestPosts.length === 0 ? (
        <div class="rounded-xl border-2 border-dashed border-stone-200 p-12 text-center">
          <p class="text-stone-400 text-sm">Posts coming soon. Season starts shortly.</p>
        </div>
      ) : (
        <div class="grid gap-4">
          {latestPosts.map((post) => (
            <PostCard
              title={post.data.title}
              date={post.data.date}
              category={post.data.category}
              type={post.data.type}
              slug={post.id}
              result={post.data.result}
              focus={post.data.focus}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Three pillars -->
  <section>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
      <h2 class="text-xs font-semibold text-stone-400 uppercase tracking-widest mb-8">
        What we write about
      </h2>
      <div class="grid sm:grid-cols-3 gap-5">
        <div class="p-5 bg-white rounded-xl border border-stone-200">
          <p class="text-xs font-semibold text-green-800 uppercase tracking-widest mb-3">Fundamentals</p>
          <p class="text-sm text-stone-600 leading-relaxed">
            Spacing, movement without the ball, floor balance. The unsexy stuff that wins games.
          </p>
        </div>
        <div class="p-5 bg-white rounded-xl border border-stone-200">
          <p class="text-xs font-semibold text-green-800 uppercase tracking-widest mb-3">Coaching</p>
          <p class="text-sm text-stone-600 leading-relaxed">
            Session plans, game breakdowns, drills worth stealing. The real work between whistles.
          </p>
        </div>
        <div class="p-5 bg-white rounded-xl border border-stone-200">
          <p class="text-xs font-semibold text-green-800 uppercase tracking-widest mb-3">Mindset</p>
          <p class="text-sm text-stone-600 leading-relaxed">
            Presence, awareness, learning to read the game. What separates players who "get it".
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
