---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const gamePosts = allPosts.filter(p => p.data.type === 'post-game');
const trainingPosts = allPosts.filter(p => p.data.type === 'post-training');

const timelinePosts = allPosts
  .filter(p => p.data.type === 'post-game' || p.data.type === 'post-training')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const typeLabel: Record<string, string> = {
  'post-game': 'Game',
  'post-training': 'Training',
};

const typeColour: Record<string, string> = {
  'post-game': 'bg-amber-50 text-amber-700 border-amber-200',
  'post-training': 'bg-green-50 text-green-800 border-green-200',
};

const dotColour: Record<string, string> = {
  'post-game': 'bg-amber-400',
  'post-training': 'bg-green-700',
};
---

<BaseLayout
  title="Coaching Journal"
  description="A season timeline — training sessions and games as the season unfolds."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <p class="text-xs font-semibold text-green-800 uppercase tracking-widest mb-4">
      Coaching Journal
    </p>
    <h1 class="text-3xl sm:text-4xl font-bold text-stone-900 mb-3">
      Season Log
    </h1>
    <p class="text-stone-500 mb-10">
      A running record of sessions and games. Updated throughout the season.
    </p>

    <!-- Season summary stats -->
    <div class="grid grid-cols-3 gap-4 mb-12">
      <div class="bg-white border border-stone-200 rounded-xl p-5">
        <p class="text-2xl font-bold text-stone-900">{gamePosts.length}</p>
        <p class="text-sm text-stone-500 mt-1">Games</p>
      </div>
      <div class="bg-white border border-stone-200 rounded-xl p-5">
        <p class="text-2xl font-bold text-stone-900">{trainingPosts.length}</p>
        <p class="text-sm text-stone-500 mt-1">Sessions</p>
      </div>
      <div class="bg-white border border-stone-200 rounded-xl p-5">
        <p class="text-2xl font-bold text-stone-900">{timelinePosts.length}</p>
        <p class="text-sm text-stone-500 mt-1">Total entries</p>
      </div>
    </div>

    {timelinePosts.length === 0 ? (
      <div class="rounded-xl border-2 border-dashed border-stone-200 p-12 text-center">
        <p class="text-stone-400 text-sm mb-1">Season entries will appear here.</p>
        <p class="text-stone-300 text-xs">First session coming soon.</p>
      </div>
    ) : (
      <div class="relative">
        <div class="absolute left-3 top-2 bottom-2 w-px bg-stone-200"></div>
        <div class="space-y-6">
          {timelinePosts.map((post) => {
            const formattedDate = post.data.date.toLocaleDateString('en-AU', {
              day: 'numeric', month: 'short', year: 'numeric',
            });
            return (
              <div class="relative pl-10">
                <div class={`absolute left-1.5 top-2 w-3 h-3 rounded-full ${dotColour[post.data.type] ?? 'bg-stone-400'}`}></div>
                <a
                  href={`/blog/${post.id}`}
                  class="block bg-white border border-stone-200 rounded-xl p-5 hover:border-green-700 hover:shadow-sm transition-all group"
                >
                  <div class="flex items-center gap-2 mb-2">
                    <span class={`text-xs font-semibold px-2 py-0.5 rounded-full border ${typeColour[post.data.type] ?? 'bg-stone-100 text-stone-600 border-stone-200'}`}>
                      {typeLabel[post.data.type]}
                    </span>
                    {post.data.result && (
                      <span class="text-xs font-mono text-stone-500">{post.data.result}</span>
                    )}
                    <span class="text-xs text-stone-400 ml-auto">{formattedDate}</span>
                  </div>
                  <p class="font-semibold text-stone-900 group-hover:text-green-800 transition-colors">
                    {post.data.title}
                  </p>
                  {post.data.focus && (
                    <p class="text-sm text-stone-500 mt-1">Focus: {post.data.focus}</p>
                  )}
                </a>
              </div>
            );
          })}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
