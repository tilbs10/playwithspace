---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Coaching Journal"
  description="A season timeline — training sessions, games, and observations as the season unfolds."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <p class="text-sm font-semibold text-orange-600 uppercase tracking-widest mb-4">
      Coaching Journal
    </p>
    <h1 class="text-3xl sm:text-4xl font-bold text-stone-900 mb-4">
      Season Log
    </h1>
    <p class="text-stone-600 mb-12">
      A running timeline of sessions and games. Updated throughout the season.
    </p>

    <!-- Season header -->
    <div class="bg-orange-50 border border-orange-200 rounded-xl p-6 mb-10">
      <p class="text-sm font-semibold text-orange-700 mb-1">Current season</p>
      <p class="text-xl font-bold text-stone-900">2026 Season</p>
      <p class="text-stone-600 text-sm mt-1">Season underway — entries coming soon.</p>
    </div>

    <!-- Placeholder timeline -->
    <div class="rounded-xl border-2 border-dashed border-stone-200 p-12 text-center">
      <p class="text-stone-400 text-sm">
        Season entries will appear here as the season progresses.
      </p>
    </div>
  </div>
</BaseLayout>
