---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

// Coaching page shows written pieces — articles, quick takes, deep dives.
// Game reviews and training logs live in the Journal.
const allPosts = await getCollection('blog', ({ data }) =>
  !data.draft && ['article', 'quick-take', 'deep-dive'].includes(data.type)
);

const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryLabels: Record<string, string> = {
  fundamentals: 'Fundamentals',
  coaching:     'Coaching',
  mindset:      'Mindset',
  stories:      'Stories',
};
---

<BaseLayout
  title="Coaching"
  description="Coaching concepts, fundamentals, and tactical thinking for basketball players and coaches."
>

  <!-- Page header -->
  <section class="bg-[#006437] py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-4">Writing</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4 leading-tight">Coaching</h1>
      <p class="text-white/60 text-base max-w-xl leading-relaxed">
        Ideas about the game that aren't tied to a specific session or result.
        The thinking behind the practice.
      </p>
    </div>
  </section>

  <!-- Posts -->
  <section class="py-16 sm:py-20 bg-[#fafaf9]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">

      {posts.length === 0 ? (
        <div class="rounded-[32px] border-2 border-dashed border-stone-300 p-16 text-center">
          <p class="text-stone-400 text-sm">No coaching articles yet — check back soon.</p>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              date={post.data.date}
              category={post.data.category}
              type={post.data.type}
              slug={post.id}
              result={post.data.result}
              focus={post.data.focus}
              heroImage={post.data.heroImage}
              heroAlt={post.data.heroAlt}
            />
          ))}
        </div>
      )}

    </div>
  </section>

</BaseLayout>
