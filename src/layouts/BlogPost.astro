---
import BaseLayout from './BaseLayout.astro';
import Newsletter from '../components/Newsletter.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  date: Date;
  category: string;
  type: string;
  result?: string;
  focus?: string;
  tags?: string[];
  heroImage?: ImageMetadata;
  heroAlt?: string;
}

const { title, date, category, type, result, focus, tags, heroImage, heroAlt } = Astro.props;

const categoryColors: Record<string, string> = {
  fundamentals: 'bg-blue-50 text-blue-700',
  coaching: 'bg-green-50 text-green-800',
  mindset: 'bg-purple-50 text-purple-700',
  stories: 'bg-amber-50 text-amber-700',
};

const typeLabel: Record<string, string> = {
  article: 'Article',
  'quick-take': 'Quick Take',
  'deep-dive': 'Deep Dive',
  'post-game': 'Game Review',
  'post-training': 'Training Log',
};

const formattedDate = date.toLocaleDateString('en-AU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title={title}
  description={`${typeLabel[type] ?? ''} — ${title}`}
  type="article"
  image={heroImage?.src}
>
  <article class="max-w-2xl mx-auto px-4 sm:px-6 py-12 sm:py-16">

    <a href="/blog" class="text-sm text-stone-400 hover:text-green-800 transition-colors mb-8 inline-block">
      ← All posts
    </a>

    <div class="flex items-center gap-2 mb-4">
      <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${categoryColors[category] ?? 'bg-stone-100 text-stone-600'}`}>
        {category}
      </span>
      <span class="text-xs text-stone-400">{typeLabel[type] ?? type}</span>
      {result && (
        <span class="text-xs font-mono text-stone-500 ml-auto">{result}</span>
      )}
    </div>

    <h1 class="text-3xl sm:text-4xl font-bold text-stone-900 leading-tight mb-3">
      {title}
    </h1>

    {focus && (
      <p class="text-stone-500 mb-3">Focus: <span class="font-medium text-stone-700">{focus}</span></p>
    )}

    <p class="text-sm text-stone-400 mb-10">{formattedDate}</p>

    {heroImage && (
      <Image
        src={heroImage}
        alt={heroAlt ?? ''}
        widths={[640, 960, 1280]}
        sizes="(max-width: 672px) 100vw, 672px"
        class="w-full rounded-2xl border border-stone-200 mb-10"
      />
    )}

    <div class="prose">
      <slot />
    </div>

    {tags && tags.length > 0 && (
      <div class="mt-10 pt-6 border-t border-stone-200">
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="text-xs bg-stone-100 text-stone-600 px-2 py-1 rounded-full">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Newsletter signup -->
    <div class="mt-12">
      <Newsletter />
    </div>

  </article>
</BaseLayout>
