---
// The ball: a small burnt-orange disc with cream seams and a print-shadow.
interface Props {
  x: number;
  y: number;
}

const { x, y } = Astro.props;
---

<g>
  <circle cx={x + 2.5} cy={y + 2.5} r="6.5" fill="#5f5546" opacity="0.18" />
  <circle cx={x} cy={y} r="6.5" fill="#c2410c" />
  <path
    d={`M ${x - 6.5} ${y} H ${x + 6.5} M ${x} ${y - 6.5} V ${y + 6.5}`}
    stroke="#f6efe2"
    stroke-width="1.1"
    fill="none"
  />
</g>
