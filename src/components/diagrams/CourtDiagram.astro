---
// Mid-century-modern basketball court diagram.
// Use inside .mdx posts, with Player / Ball / MoveArrow / PassArrow / Spot
// components in the slot.
//
// Coordinate system: 20px per metre, court boundary starts at (20, 20).
//   half: viewBox 340x320, basket at the top, halfway line at the bottom.
//   full: viewBox 600x340, baskets left and right, attack reads left→right.
interface Props {
  court?: 'half' | 'full';
  title: string;      // accessible description of the diagram
  caption?: string;   // printed below in small caps
}

const { court = 'half', title, caption } = Astro.props;

const viewBox = court === 'half' ? '0 0 340 320' : '0 0 600 340';

// MCM palette: warm cream ground, taupe linework, colour-block paint
const cream = '#f6efe2';
const line  = '#8a7a63';
const paint = '#e9dfc6';
const rim   = '#c2410c';
---

<figure class="court-diagram">
  <svg viewBox={viewBox} role="img" aria-label={title} xmlns="http://www.w3.org/2000/svg">
    <title>{title}</title>

    {court === 'half' ? (
      <g stroke-linecap="round" stroke-linejoin="round">
        <!-- cream card -->
        <rect x="0" y="0" width="340" height="320" rx="18" fill={cream} />
        <!-- key, painted flat -->
        <rect x="121" y="20" width="98" height="116" fill={paint} stroke={line} stroke-width="2.5" />
        <!-- court boundary (baseline at top, halfway at bottom) -->
        <rect x="20" y="20" width="300" height="280" fill="none" stroke={line} stroke-width="2.5" />
        <!-- free-throw circle -->
        <circle cx="170" cy="136" r="36" fill="none" stroke={line} stroke-width="2.5" />
        <!-- three-point line -->
        <path d="M 38 20 L 38 80 A 135 135 0 0 0 302 80 L 302 20" fill="none" stroke={line} stroke-width="2.5" />
        <!-- centre circle (half, on the halfway line) -->
        <path d="M 134 300 A 36 36 0 0 1 206 300" fill="none" stroke={line} stroke-width="2.5" />
        <!-- backboard + rim -->
        <line x1="152" y1="44" x2="188" y2="44" stroke={line} stroke-width="4" />
        <circle cx="170" cy="51.5" r="5.5" fill="none" stroke={rim} stroke-width="2.5" />
      </g>
    ) : (
      <g stroke-linecap="round" stroke-linejoin="round">
        <!-- cream card -->
        <rect x="0" y="0" width="600" height="340" rx="18" fill={cream} />
        <!-- keys, painted flat -->
        <rect x="20" y="121" width="116" height="98" fill={paint} stroke={line} stroke-width="2.5" />
        <rect x="464" y="121" width="116" height="98" fill={paint} stroke={line} stroke-width="2.5" />
        <!-- court boundary -->
        <rect x="20" y="20" width="560" height="300" fill="none" stroke={line} stroke-width="2.5" />
        <!-- halfway line + centre circle -->
        <line x1="300" y1="20" x2="300" y2="320" stroke={line} stroke-width="2.5" />
        <circle cx="300" cy="170" r="36" fill="none" stroke={line} stroke-width="2.5" />
        <!-- free-throw circles -->
        <circle cx="136" cy="170" r="36" fill="none" stroke={line} stroke-width="2.5" />
        <circle cx="464" cy="170" r="36" fill="none" stroke={line} stroke-width="2.5" />
        <!-- three-point lines -->
        <path d="M 20 38 L 80 38 A 135 135 0 0 1 80 302 L 20 302" fill="none" stroke={line} stroke-width="2.5" />
        <path d="M 580 38 L 520 38 A 135 135 0 0 0 520 302 L 580 302" fill="none" stroke={line} stroke-width="2.5" />
        <!-- backboards + rims -->
        <line x1="44" y1="152" x2="44" y2="188" stroke={line} stroke-width="4" />
        <circle cx="51.5" cy="170" r="5.5" fill="none" stroke={rim} stroke-width="2.5" />
        <line x1="556" y1="152" x2="556" y2="188" stroke={line} stroke-width="4" />
        <circle cx="548.5" cy="170" r="5.5" fill="none" stroke={rim} stroke-width="2.5" />
      </g>
    )}

    <slot />
  </svg>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .court-diagram {
    margin: 2.5rem 0;
  }
  .court-diagram svg {
    display: block;
    width: 100%;
    height: auto;
  }
  .court-diagram figcaption {
    margin-top: 0.85rem;
    text-align: center;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #8a7a63;
  }
</style>
