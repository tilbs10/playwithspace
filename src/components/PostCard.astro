---
interface Props {
  title: string;
  date: Date;
  category: string;
  type: string;
  slug: string;
  result?: string;
  focus?: string;
}

const { title, date, category, type, slug, result, focus } = Astro.props;

const categoryColors: Record<string, string> = {
  fundamentals: 'bg-blue-50 text-blue-700',
  coaching: 'bg-green-50 text-green-800',
  mindset: 'bg-purple-50 text-purple-700',
  stories: 'bg-amber-50 text-amber-700',
};

const typeLabel: Record<string, string> = {
  article: 'Article',
  'post-game': 'Game Review',
  'post-training': 'Training Log',
};

const formattedDate = date.toLocaleDateString('en-AU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-green-700 hover:shadow-sm transition-all group"
>
  <div class="flex items-center gap-2 mb-3">
    <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${categoryColors[category] ?? 'bg-stone-100 text-stone-600'}`}>
      {category}
    </span>
    <span class="text-xs text-stone-400">{typeLabel[type] ?? type}</span>
    {result && (
      <span class="text-xs font-mono text-stone-500 ml-auto">{result}</span>
    )}
  </div>

  <h2 class="font-bold text-stone-900 text-lg leading-snug mb-2 group-hover:text-green-800 transition-colors">
    {title}
  </h2>

  {focus && (
    <p class="text-sm text-stone-500 mb-2">Focus: {focus}</p>
  )}

  <p class="text-xs text-stone-400 mt-3">{formattedDate}</p>
</a>
