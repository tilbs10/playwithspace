<footer class="bg-emerald-950 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16">

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8 mb-12">
      <div class="flex items-center gap-2.5">
        <div class="w-7 h-7 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
          <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 text-white" stroke="currentColor" stroke-width="1.5">
