---
const navLinks = [
  { href: '/coaching', label: 'Coaching' },
  { href: '/drills',   label: 'Drills' },
  { href: '/journal',  label: 'The Court' },
  { href: '/about',    label: 'About' },
];

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<!--
  Header behaviour:
  - On homepage: starts transparent (overlaid on hero image), transitions to
    dark emerald on scroll.
  - On all other pages: solid dark emerald immediately.
-->
<header
  id="site-header"
  class={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${
    isHome ? 'bg-transparent' : 'bg-emerald-950/95 backdrop-blur-md border-b border-white/10'
  }`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="w-7 h-7 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 text-white" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="9"/>
          <path d="M12 3a9 9 0 0 1 0 18"   stroke-linecap="round"/>
          <path d="M3 12h18"                stroke-linecap="round"/>
          <path d="M12 3c2.5 2.5 4 5.6 4 9s-1.5 6.5-4 9" stroke-linecap="round"/>
        </svg>
      </div>
      <span class="text-sm font-bold text-white tracking-tight">Play With Space</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm font-medium px-4 py-2 rounded-full transition-colors ${
            currentPath.startsWith(link.href)
              ? 'bg-white/15 text-white'
              : 'text-white/70 hover:text-white hover:bg-white/10'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Join the Team CTA -->
    <div class="flex items-center gap-3">
      <a
        href="/contact"
        class="hidden sm:inline-flex items-center gap-2 bg-white text-[#006437] font-bold text-sm px-5 py-2.5 rounded-full hover:bg-stone-100 transition-colors"
      >
        Join the Team
      </a>

      <!-- Mobile hamburger -->
      <details class="sm:hidden group relative">
        <summary class="list-none cursor-pointer p-2 rounded-full text-white/70 hover:text-white hover:bg-white/10 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </summary>
        <div class="absolute right-0 top-12 bg-emerald-950 border border-white/10 rounded-3xl shadow-2xl p-3 flex flex-col gap-1 min-w-48 z-50">
          {navLinks.map(link => (
            <a
              href={link.href}
              class="text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 px-4 py-2.5 rounded-2xl transition-colors"
            >
              {link.label}
            </a>
          ))}
          <div class="border-t border-white/10 mt-2 pt-2">
            <a href="/contact" class="block text-sm font-bold text-center bg-white text-[#006437] px-4 py-2.5 rounded-2xl">
              Join the Team
            </a>
          </div>
        </div>
      </details>
    </div>

  </div>
</header>

{isHome && (
  <!-- Scroll listener: swap transparent → dark emerald once user scrolls past hero -->
  <script>
    const header = document.getElementById('site-header');
    if (header) {
      const onScroll = () => {
        if (window.scrollY > 80) {
          header.classList.add('bg-emerald-950/95', 'backdrop-blur-md', 'border-b', 'border-white/10');
          header.classList.remove('bg-transparent');
        } else {
          header.classList.remove('bg-emerald-950/95', 'backdrop-blur-md', 'border-b', 'border-white/10');
          header.classList.add('bg-transparent');
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  </script>
)}
