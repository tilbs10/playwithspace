---
const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/journal', label: 'Coaching Journal' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-stone-200 bg-stone-50 sticky top-0 z-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">

    <!-- Site name -->
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-xl font-bold text-stone-900 tracking-tight group-hover:text-orange-600 transition-colors">
        Play With Space
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm font-medium transition-colors hover:text-orange-600 ${
            currentPath.startsWith(link.href)
              ? 'text-orange-600'
              : 'text-stone-600'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile nav toggle (simple version — no JS needed with CSS) -->
    <details class="sm:hidden group">
      <summary class="list-none cursor-pointer p-1 text-stone-600 hover:text-orange-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </summary>
      <div class="absolute right-4 top-16 bg-white border border-stone-200 rounded-lg shadow-lg p-4 flex flex-col gap-3 min-w-48">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-sm font-medium text-stone-700 hover:text-orange-600 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
    </details>

  </div>
</header>
