---
// "The Leather Hit" badge — persistent across all pages.
// Positioned fixed bottom-right. Orange leather texture with basketball icon + label.
---

<a
  href="/contact"
  aria-label="Book a session — The Leather Hit"
  class="fixed bottom-6 right-6 z-50 flex items-center gap-3 pr-4 rounded-full shadow-2xl hover:scale-105 active:scale-95 transition-transform group"
  style="background-color: #c2410c; background-image: url('https://www.transparenttextures.com/patterns/leather.png');"
>
  <!-- Basketball icon circle -->
  <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0"
       style="background-color: rgba(0,0,0,0.2);">
    <svg viewBox="0 0 32 32" fill="none" class="w-6 h-6 text-white" stroke="currentColor" stroke-width="1.5">
      <circle cx="16" cy="16" r="12"/>
      <path d="M16 4a12 12 0 0 1 0 24"  stroke-linecap="round"/>
      <path d="M4 16h24"                 stroke-linecap="round"/>
      <path d="M16 4c3 3.5 5 7.5 5 12s-2 8.5-5 12" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- Text label -->
  <div class="flex flex-col leading-none py-3">
    <span class="text-[9px] font-semibold text-white/60 uppercase tracking-widest">Book Session</span>
    <span class="text-xs font-bold text-white mt-0.5">The Leather Hit</span>
  </div>
</a>
