---
---

<div class="bg-green-800 rounded-2xl px-8 py-10 text-center">
  <p class="text-xs font-semibold text-green-300 uppercase tracking-widest mb-3">
    Stay in the loop
  </p>
  <h2 class="text-2xl font-bold text-white mb-3">
    Get new posts by email
  </h2>
  <p class="text-green-200 text-sm mb-6 max-w-sm mx-auto">
    Session breakdowns, game reviews, and coaching ideas — straight to your inbox when they're published.
  </p>

  <form
    action="https://buttondown.com/api/emails/embed-subscribe/playwithspace"
    method="post"
    class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
  >
    <input
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      class="flex-1 px-4 py-3 rounded-lg text-stone-900 text-sm focus:outline-none focus:ring-2 focus:ring-white"
    />
    <button
      type="submit"
      class="bg-white text-green-800 font-semibold px-6 py-3 rounded-lg text-sm hover:bg-green-50 transition-colors whitespace-nowrap"
    >
      Subscribe
    </button>
  </form>

  <p class="text-green-400 text-xs mt-4">No spam. Unsubscribe any time.</p>
</div>
